# Redis connection string (optional - caching will be skipped if not set)
REDIS_URL=redis://localhost:6379

# SearXNG instance URL (optional - falls back to DuckDuckGo if not set)
SEARXNG_URL=http://localhost:8888

# Anthropic API key for agent_extract endpoint (optional - falls back to CSS selectors)
ANTHROPIC_API_KEY=

# Ollama URL for local LLM extraction (optional - falls back to CSS selectors)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Cache TTL in seconds (default: 3600)
AGENTFETCH_CACHE_TTL=3600

# Maximum parallel requests for batch operations (default: 5)
AGENTFETCH_MAX_CONCURRENCY=5

# Injection firewall mode: strict|warn|off (default: strict)
AGENTFETCH_INJECTION_FIREWALL=strict

# API server port (default: 8080)
AGENTFETCH_PORT=8080

# Static HTTP fetch timeout in seconds (default: 15)
AGENTFETCH_STATIC_TIMEOUT=15

# Headless browser timeout in seconds (default: 30)
AGENTFETCH_BROWSER_TIMEOUT=30

# Path to Netscape-format cookies file for authenticated pages
AGENTFETCH_COOKIES_FILE=

# Robots.txt compliance (true|false, default: false)
AGENTFETCH_ROBOTS_CHECK=false

# Proxy rotation configuration
# Comma-separated list of proxy URLs, or JSON array
# Examples:
#   AGENTFETCH_PROXY_LIST=http://user:pass@proxy1:8080,http://user:pass@proxy2:8080
#   AGENTFETCH_PROXY_LIST=[{"url":"http://proxy1:8080"},{"url":"http://proxy2:8080"}]
AGENTFETCH_PROXY_LIST=
AGENTFETCH_PROXY_STRATEGY=round-robin
