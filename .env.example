# Redis connection string (optional - caching will be skipped if not set)
REDIS_URL=redis://localhost:6379

# SearXNG instance URL (optional - falls back to DuckDuckGo if not set)
SEARXNG_URL=http://localhost:8888

# Anthropic API key for agent_extract endpoint (optional - falls back to CSS selectors)
ANTHROPIC_API_KEY=

# Cache TTL in seconds (default: 3600)
AGENTFETCH_CACHE_TTL=3600

# Maximum parallel requests for batch operations (default: 5)
AGENTFETCH_MAX_CONCURRENCY=5

# Injection firewall mode: strict|warn|off (default: strict)
AGENTFETCH_INJECTION_FIREWALL=strict

# API server port (default: 8080)
AGENTFETCH_PORT=8080
